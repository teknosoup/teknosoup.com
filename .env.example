# PostgreSQL (for Strapi)
POSTGRES_PASSWORD=change_me_strong_password

# Strapi secrets — generate each with: openssl rand -base64 32
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=change_me
STRAPI_ADMIN_JWT_SECRET=change_me
STRAPI_TRANSFER_TOKEN_SALT=change_me
STRAPI_JWT_SECRET=change_me

# Migration — fill in after creating API token in Strapi admin
STRAPI_API_TOKEN=

# Migration options (optional)
DRY_RUN=false
LIMIT=
