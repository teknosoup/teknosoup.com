# Ghost MySQL connection
GHOST_DB_HOST=127.0.0.1
GHOST_DB_PORT=3306
GHOST_DB_USER=ghost
GHOST_DB_PASSWORD=
GHOST_DB_NAME=ghost

# Path to Ghost content directory (where images are stored)
# If running locally with Docker, mount the volume and set this to the mounted path
# e.g. docker cp ghost-container:/var/lib/ghost/content ./ghost-content
# then set: GHOST_CONTENT_PATH=./ghost-content
GHOST_CONTENT_PATH=/var/lib/ghost/content

# Strapi connection
STRAPI_API_URL=http://localhost:1337
# Generate a full-access API token in Strapi Admin → Settings → API Tokens
STRAPI_API_TOKEN=

# Set to true to preview what would happen without creating anything in Strapi
DRY_RUN=false

# Only migrate this many posts (useful for testing). Leave empty to migrate all.
LIMIT=
